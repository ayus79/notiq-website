---
const steps = [
  { n: '01', title: 'Install',  body: 'pip install notiq - works in any Python environment, no build step needed.', code: 'pip install notiq' },
  { n: '02', title: 'Connect',  body: 'Link your channels from the dashboard. Paste an API key per provider, done in under 5 minutes.', code: 'notiq channels add email sms' },
  { n: '03', title: 'Ship',     body: 'Call client.notify() anywhere in your codebase. We handle routing, retries, and delivery.', code: 'client.notify(to=user, event="welcome")' },
];
---

<section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  <div class="mb-10 sm:mb-12">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink dark:text-zinc-50 mb-2">Up and running in minutes</h2>
    <p class="text-sm sm:text-base text-muted dark:text-zinc-400">No boilerplate. No SMTP debugging. No email server config.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    {steps.map(({ n, title, body, code }) => (
      <div class="rounded-2xl border border-border dark:border-zinc-800 p-5 sm:p-7 bg-paper dark:bg-zinc-900">
        <span class="text-xs font-semibold text-orange-500 tracking-widest">{n}</span>
        <h3 class="text-base sm:text-lg font-bold mt-2 mb-2 text-ink dark:text-zinc-50">{title}</h3>
        <p class="text-sm text-muted dark:text-zinc-400 leading-relaxed mb-5">{body}</p>
        <code class="block px-3 py-2.5 rounded-lg bg-zinc-950 text-orange-300 font-mono text-xs overflow-x-auto border border-zinc-800 whitespace-pre">
$ {code}
        </code>
      </div>
    ))}
  </div>
</section>
