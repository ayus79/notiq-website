---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="max-w-5xl mx-auto px-4 sm:px-6 pt-14 pb-20 sm:pt-20 sm:pb-24 lg:pt-28 lg:pb-32">
  <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

    <div>
      <p class="text-xs font-semibold tracking-widest uppercase text-orange-500 mb-4 sm:mb-5 animate-rise">
        Open-source · Multi-channel notifications
      </p>
      <h1 class="text-[2.6rem] sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.08] text-ink dark:text-zinc-50 mb-4 sm:mb-5 animate-rise-1">
        The notification layer<br />
        <span class="text-orange-500">your app was missing.</span>
      </h1>
      <p class="text-base sm:text-lg text-muted dark:text-zinc-400 leading-relaxed mb-7 sm:mb-8 max-w-md animate-rise-2">
        notiq is a multi-channel notification platform. Stop juggling separate libraries for every channel — one client handles it all.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 animate-rise-3">
        <a href={`${base}/pricing`}
           class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl bg-orange-500 hover:bg-orange-600 text-white font-semibold text-sm transition-colors shadow-lg shadow-orange-500/25">
          Start for free
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href={`${base}/features`}
           class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl border border-border dark:border-zinc-700 text-ink dark:text-zinc-200 font-semibold text-sm hover:border-orange-400 dark:hover:border-orange-500 transition-colors">
          See how it works
        </a>
      </div>

      <div class="mt-8 sm:mt-10 flex flex-wrap gap-2 animate-rise-3">
        {['Email', 'SMS', 'In-app'].map(ch => (
          <span class="px-3 py-1 rounded-full text-xs font-medium border border-border dark:border-zinc-800 text-muted dark:text-zinc-500 bg-paper dark:bg-zinc-900">
            {ch}
          </span>
        ))}
      </div>
    </div>

    <div class="animate-rise-2 w-full min-w-0">
      <div class="rounded-2xl overflow-hidden border border-zinc-800 shadow-2xl bg-zinc-950">
        <div class="flex items-center gap-1.5 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
          <span class="ml-3 text-xs font-mono text-zinc-500">notify.py</span>
        </div>
        <pre class="p-4 sm:p-5 text-[12px] sm:text-[13px] font-mono leading-[1.9] overflow-x-auto"><code
><span class="text-violet-400">import</span> <span class="text-zinc-100">notiq</span>

<span class="text-zinc-500"># one client, every channel</span>
<span class="text-sky-400">client</span> <span class="text-zinc-400">=</span> <span class="text-zinc-100">notiq</span><span class="text-zinc-400">.</span><span class="text-yellow-300">Client</span><span class="text-zinc-400">(</span><span class="text-green-400">api_key</span><span class="text-zinc-400">=</span><span class="text-orange-300">"nq_live_..."</span><span class="text-zinc-400">)</span>

<span class="text-zinc-500"># send across multiple channels in one call</span>
<span class="text-sky-400">client</span><span class="text-zinc-400">.</span><span class="text-yellow-300">notify</span><span class="text-zinc-400">(</span>
    <span class="text-green-400">to</span>       <span class="text-zinc-400">=</span> <span class="text-orange-300">"sarah@example.com"</span><span class="text-zinc-400">,</span>
    <span class="text-green-400">event</span>    <span class="text-zinc-400">=</span> <span class="text-orange-300">"user.signup"</span><span class="text-zinc-400">,</span>
    <span class="text-green-400">channels</span> <span class="text-zinc-400">= [</span><span class="text-orange-300">"email"</span><span class="text-zinc-400">,</span> <span class="text-orange-300">"sms"</span><span class="text-zinc-400">,</span> <span class="text-orange-300">"in_app"</span><span class="text-zinc-400">],</span>
    <span class="text-green-400">data</span>     <span class="text-zinc-400">= {</span>
        <span class="text-orange-300">"name"</span><span class="text-zinc-400">:</span>  <span class="text-orange-300">"Sarah"</span><span class="text-zinc-400">,</span>
        <span class="text-orange-300">"plan"</span><span class="text-zinc-400">:</span>  <span class="text-orange-300">"Pro"</span><span class="text-zinc-400">,</span>
    <span class="text-zinc-400">},</span>
<span class="text-zinc-400">)</span>

<span class="text-zinc-500"># that's it.</span>
</code></pre>
      </div>
      <div class="mt-3 flex items-center gap-3 px-4 py-2.5 rounded-xl bg-zinc-900 border border-zinc-800 w-fit max-w-full">
        <span class="text-orange-400 font-mono text-xs">$</span>
        <span class="font-mono text-sm text-zinc-300 truncate">pip install notiq</span>
        <button onclick="navigator.clipboard.writeText('pip install notiq')"
          class="ml-1 flex-shrink-0 text-zinc-600 hover:text-zinc-300 transition-colors" title="Copy">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</section>
