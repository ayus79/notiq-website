---
import ThemeToggle from './ThemeToggle.astro';
const nav = [
  { href: '/',         label: 'Home' },
  { href: '/about',    label: 'About' },
  { href: '/features', label: 'Features' },
  { href: '/pricing',  label: 'Pricing' },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border dark:border-zinc-800 bg-canvas/90 dark:bg-zinc-950/90 backdrop-blur-sm">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">

    <a href="/" class="flex items-center gap-2.5 font-semibold text-base tracking-tight">
      <span class="w-7 h-7 rounded-lg bg-orange-500 flex items-center justify-center">
        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8 1a1.5 1.5 0 0 0-1.5 1.5V3A5 5 0 0 0 3 7.5v2.379l-.854.853A.5.5 0 0 0 2.5 11.5H6a2 2 0 0 0 4 0h3.5a.5.5 0 0 0 .354-.854L13 9.879V7.5A5 5 0 0 0 9.5 3v-.5A1.5 1.5 0 0 0 8 1z"/>
        </svg>
      </span>
      notiq
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      {nav.map(({ href, label }) => {
        const active = href === '/' ? path === '/' : path.startsWith(href);
        return (
          <a href={href} class={`transition-colors ${active ? 'text-orange-500 font-medium' : 'text-muted dark:text-zinc-400 hover:text-ink dark:hover:text-zinc-100'}`}>
            {label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a href="https://github.com" target="_blank" rel="noopener noreferrer"
         class="hidden md:inline-flex items-center gap-1.5 text-sm font-medium px-4 py-1.5 rounded-lg border border-border dark:border-zinc-700 hover:border-orange-400 hover:text-orange-500 transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="/pricing" class="text-sm font-semibold px-4 py-1.5 rounded-lg bg-orange-500 hover:bg-orange-600 text-white transition-colors">
        Get started
      </a>

      <!-- Mobile menu button -->
      <button id="mob-btn" class="md:hidden p-1.5 rounded-md text-muted hover:text-ink dark:hover:text-zinc-100 transition-colors">
        <svg id="ico-open"  class="w-5 h-5"        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="ico-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mob-menu" class="hidden md:hidden border-t border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex flex-col gap-1 text-sm">
      {nav.map(({ href, label }) => (
        <a href={href} class="px-3 py-2.5 rounded-lg text-muted dark:text-zinc-400 hover:text-ink dark:hover:text-zinc-100 hover:bg-paper dark:hover:bg-zinc-900 transition-colors">{label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mob-btn');
  const menu = document.getElementById('mob-menu');
  const open = document.getElementById('ico-open');
  const close = document.getElementById('ico-close');
  btn?.addEventListener('click', () => {
    const show = menu?.classList.toggle('hidden') === false;
    open?.classList.toggle('hidden', show);
    close?.classList.toggle('hidden', !show);
  });
</script>
