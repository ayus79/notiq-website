---
const channels = [
  {
    name: 'Email',
    desc: 'Transactional and marketing emails via SMTP, SendGrid, or Mailgun',
    color: 'bg-green-500/10 text-green-600 dark:text-green-400 border-green-500/20',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    name: 'SMS',
    desc: 'Send text messages globally via Twilio or AWS SNS',
    color: 'bg-sky-500/10 text-sky-600 dark:text-sky-400 border-sky-500/20',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>`,
  },
  {
    name: 'In-app',
    desc: 'Real-time in-app notifications surfaced directly inside your product',
    color: 'bg-orange-500/10 text-orange-600 dark:text-orange-400 border-orange-500/20',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>`,
  },
];
---

<section class="bg-paper dark:bg-zinc-900/50 border-y border-border dark:border-zinc-800 py-20">
  <div class="max-w-5xl mx-auto px-5">
    <div class="mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-ink dark:text-zinc-50 mb-2">One SDK. Three channels.</h2>
      <p class="text-muted dark:text-zinc-400">Email, SMS, and in-app — the three channels that actually matter.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {channels.map(({ name, desc, color, icon }) => (
        <div class="rounded-2xl border border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-900 p-6 hover:shadow-md transition-shadow">
          <div class={`inline-flex p-3 rounded-xl mb-4 border ${color}`} set:html={icon} />
          <h3 class="font-semibold text-ink dark:text-zinc-100 mb-1">{name}</h3>
          <p class="text-sm text-muted dark:text-zinc-400 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
