---
---

<section class="bg-paper dark:bg-zinc-900/50 border-y border-border dark:border-zinc-800 py-16 sm:py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <div class="mb-10 sm:mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink dark:text-zinc-50 mb-2">Everything you need, nothing you don't</h2>
      <p class="text-sm sm:text-base text-muted dark:text-zinc-400">Built for teams who want to ship fast and stay reliable.</p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">

      <!-- Large: Multi-channel - spans 2 cols on sm+ -->
      <div class="sm:col-span-2 rounded-2xl border border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-900 p-5 sm:p-7 overflow-hidden">
        <span class="inline-block mb-3 text-xs font-semibold px-2.5 py-1 rounded-md bg-orange-500/10 text-orange-500 border border-orange-500/20">Core feature</span>
        <h3 class="text-lg sm:text-xl font-bold mb-2 text-ink dark:text-zinc-50">One call. Three channels.</h3>
        <p class="text-sm text-muted dark:text-zinc-400 mb-5 max-w-sm">Email, SMS, and in-app - managed from a single Python client. No more juggling separate SDKs.</p>
        <div class="flex flex-wrap gap-2">
          {[
            { name: 'Email',  color: 'bg-green-500/10 text-green-600 dark:text-green-400 border-green-500/20' },
            { name: 'SMS',    color: 'bg-sky-500/10 text-sky-600 dark:text-sky-400 border-sky-500/20' },
            { name: 'In-app', color: 'bg-orange-500/10 text-orange-600 dark:text-orange-400 border-orange-500/20' },
          ].map(({ name, color }) => (
            <span class={`px-3 py-1.5 rounded-lg text-xs font-semibold border ${color}`}>{name}</span>
          ))}
        </div>
      </div>

      <!-- Python SDK -->
      <div class="rounded-2xl border border-border dark:border-zinc-800 bg-zinc-950 p-5 sm:p-6 overflow-hidden">
        <h3 class="text-sm font-semibold text-zinc-50 mb-3">Python SDK</h3>
        <pre class="text-[11px] font-mono leading-relaxed text-zinc-400 overflow-x-auto"><code><span class="text-violet-400">pip</span> <span class="text-zinc-200">install notiq</span>

<span class="text-zinc-600"># async support</span>
<span class="text-sky-400">await</span> <span class="text-zinc-200">client</span><span class="text-zinc-400">.</span><span class="text-yellow-300">notify</span><span class="text-zinc-400">(</span>
  <span class="text-green-400">to</span><span class="text-zinc-400">=</span><span class="text-orange-300">user.email</span><span class="text-zinc-400">,</span>
  <span class="text-green-400">event</span><span class="text-zinc-400">=</span><span class="text-orange-300">"alert"</span><span class="text-zinc-400">,</span>
<span class="text-zinc-400">)</span></code></pre>
        <p class="mt-4 text-xs text-zinc-500">Typed · Async · mypy-friendly</p>
      </div>

      <!-- Analytics -->
      <div class="rounded-2xl border border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-900 p-5 sm:p-7">
        <div class="text-3xl sm:text-4xl font-bold text-ink dark:text-zinc-50 mb-1">99.4<span class="text-orange-500">%</span></div>
        <p class="text-sm font-semibold text-ink dark:text-zinc-200 mb-1">Delivery rate</p>
        <p class="text-xs text-muted dark:text-zinc-500">Real-time delivery logs, failure alerts, and per-channel analytics built in.</p>
      </div>

      <!-- Templates -->
      <div class="rounded-2xl border border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-900 p-5 sm:p-7">
        <div class="mb-3 w-9 h-9 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-ink dark:text-zinc-200 mb-1">Template engine</h3>
        <p class="text-xs text-muted dark:text-zinc-500">Write once. Reuse across every channel. Variables, conditions, layouts.</p>
      </div>

      <!-- Retries -->
      <div class="rounded-2xl border border-border dark:border-zinc-800 bg-canvas dark:bg-zinc-900 p-5 sm:p-7">
        <div class="mb-3 w-9 h-9 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-500">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-ink dark:text-zinc-200 mb-1">Smart retries</h3>
        <p class="text-xs text-muted dark:text-zinc-500">Exponential backoff, dead-letter queues, fallback channels. Delivery you can trust.</p>
      </div>

    </div>
  </div>
</section>
